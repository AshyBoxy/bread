{
    "include": [
        "src/**/*",
        "src/**/*.json",
        "global.d.ts"
    ],
    "exclude": [
        "src/framework/*.js",
        "src/framework/*.json"
    ],
    "compilerOptions": {
        "outDir": "dist",
        "allowJs": true,
        "checkJs": true,
        "listEmittedFiles": true,
        "module": "ESNext",
        "strict": true,
        "noImplicitReturns": true,
        "noUnusedLocals": true,
        "removeComments": true,
        "moduleResolution": "bundler",
        "target": "es2025",
        "allowSyntheticDefaultImports": true,
        "resolveJsonModule": true,
        "sourceMap": true,
        "types": [
            "node"
        ],
        "rootDir": "./src"
    }
}
